# Copia este archivo como .env y rellena los valores.
# (NO subas .env a GitHub: ya esta en .gitignore)

# Token de larga duracion de Instagram
# (panel de Meta -> Instagram -> Configuracion de la API con inicio de sesion
#  de Instagram -> Generar tokens de acceso)
IG_ACCESS_TOKEN=PEGA_AQUI_TU_TOKEN

# ID de tu cuenta de Instagram (numero)
IG_USER_ID=17841476559346371

# Base publica donde se sirven las imagenes (SIN barra final).
# GitHub Pages de este proyecto:
IMAGE_BASE_URL=https://ujnapego.github.io/senthia-core

# Opcional
GRAPH_VERSION=v23.0
