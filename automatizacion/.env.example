# Copia este archivo como .env y rellena los valores.
# (NO subas .env a GitHub: ya esta en .gitignore)

# Token de acceso de larga duracion (Page token o System User token)
META_ACCESS_TOKEN=PEGA_AQUI_TU_TOKEN

# ID de tu cuenta de Instagram Business (numero largo)
IG_USER_ID=1784xxxxxxxxxxx

# ID de tu pagina de Facebook (numero largo)
FB_PAGE_ID=1029xxxxxxxxxx

# Base publica donde se sirven las imagenes (SIN barra final).
# GitHub Pages de este proyecto:
IMAGE_BASE_URL=https://ujnapego.github.io/senthia-core

# Opcionales
GRAPH_VERSION=v21.0
TARGETS=instagram,facebook
